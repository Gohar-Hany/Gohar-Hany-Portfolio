      "parameters": {
        "jsCode": "// الوصول إلى مصفوفة 'elements' من المدخلات\nconst elements = items[0].json.elements;\n\n// فلترة المصفوفة بناءً على الشروط المطلوبة\nconst qualifiedLeads = elements.filter(element => {\n  \n  // أولاً، نتأكد أن العنصر يحتوي على 'tags' أصلاً، لو لا، يتم استبعاده\n  if (!element.tags) {\n    return false;\n  }\n\n  // الشرط الأول: التأكد من وجود اسم بأي صيغة\n  const hasName = element.tags.name || element.tags['name:en'] || element.tags['name:ar'];\n\n  // الشرط الثاني: التأكد من وجود أي وسيلة تواصل\n  const hasContactInfo = element.tags.phone || element.tags.website || element.tags.email;\n\n  // إرجاع 'true' فقط إذا تحقق الشرطان معاً\n  return hasName && hasContactInfo;\n});\n\n// إرجاع قائمة الـ Leads عالية الجودة النهائية\nreturn qualifiedLeads;"
      },

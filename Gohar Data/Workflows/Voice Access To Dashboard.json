      "parameters": {
        "jsCode": "// استخراج الصورة وتحويلها لبيانات جاهزة للإرسال\n// Extract Base64 and MimeType safely\n\nconst binaryKey = 'data'; // Default n8n binary key name\nconst binaryData = items[0].binary[binaryKey];\n\nif (!binaryData) {\n  throw new Error(\"No file uploaded! Please upload an image in the trigger node.\");\n}\n\nreturn [\n  {\n    json: {\n      base64: binaryData.data,\n      mimeType: binaryData.mimeType,\n      fileName: binaryData.fileName\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [

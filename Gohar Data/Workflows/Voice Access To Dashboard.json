    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_GROQ_API_KEY"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "meta-llama/llama-4-scout-17b-16e-instruct"
            },
            {
              "name": "response_format",
              "value": "={{ {\"type\": \"json_object\"} }}"
            },
            {
              "name": "messages",
              "value": "={{ [\n  {\n    \"role\": \"user\",\n    \"content\": [\n      {\n        \"type\": \"text\",\n        \"text\": \"Analyze this payment receipt image deeply (likely Instapay or Bank Transfer). Extract ALL details into a strict JSON format.\\n\\nRequired Fields:\\n- is_receipt: (boolean)\\n- status: (string, e.g., 'Successful' or 'Pending')\\n- total_amount: (number)\\n- currency: (string, e.g., 'EGP')\\n- date: (string, format YYYY-MM-DD)\\n- time: (string, format HH:MM)\\n- reference_number: (string, CRITICAL for tracking)\\n- sender_name: (string)\\n- receiver_name: (string)\\n- receiver_phone: (string, if available)\\n- category: (string, e.g., 'Living Expenses' or notes)\\n- bank_name: (string)\\n\\nIf a field is not found, return null.\"\n      },\n      {\n        \"type\": \"image_url\",\n        \"image_url\": {\n          \"url\": `data:${$json.mimeType};base64,${$json.base64}`\n        }\n      }\n    ]\n  }\n] }}"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        4016,

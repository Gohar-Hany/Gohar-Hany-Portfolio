      ],
      "id": "659e26b2-48ff-4bc6-9625-33c885c98daf",
      "name": "Groq - Vision Analysis"
    },
    {
      "parameters": {
        "jsCode": "// 1. استخراج النص الخام من رد Groq\n// Accessing the nested path safely\nconst choice = items[0].json.choices && items[0].json.choices[0];\nconst rawContent = choice ? choice.message.content : \"{}\";\n\n// 2. تنظيف النص من أي زيادات (Markdown, Code Blocks)\n// Removes ```json, ```, and extra whitespace\nlet cleanContent = rawContent\n  .replace(/```json/g, '')\n  .replace(/```/g, '')\n  .trim();\n\n// 3. محاولة تحويل النص لـ JSON\ntry {\n  // Parse the clean string\n  const parsedData = JSON.parse(cleanContent);\n\n  // 4. تجهيز كائن البيانات النهائي (لضمان وجود كل الحقول)\n  // We explicitly map fields to ensure they exist (defaulting to null if missing)\n  const finalOutput = {\n    is_receipt: parsedData.is_receipt || false,\n    status: parsedData.status || null,\n    total_amount: parsedData.total_amount || parsedData.total || null, // Handle variations\n    currency: parsedData.currency || \"EGP\",\n    date: parsedData.date || null,\n    time: parsedData.time || null,\n    reference_number: parsedData.reference_number || parsedData.transaction_id || null,\n    sender: parsedData.sender_name || null,\n    receiver: parsedData.receiver_name || null,\n    receiver_phone: parsedData.receiver_phone || null,\n    bank: parsedData.bank_name || parsedData.merchant || null,\n    category: parsedData.category || null,\n    \n    // بنحتفظ بالرد الأصلي عشان لو حبيت تراجعه\n    _raw_response: rawContent\n  };\n\n  return [{ json: finalOutput }];\n\n} catch (error) {\n  // في حالة الفشل، رجع رسالة خطأ مع النص الأصلي عشان تعرف السبب\n  return [{ \n    json: { \n      error: \"Failed to parse JSON\", \n      message: error.message,\n      raw_input: cleanContent \n    } \n  }];\n}"
      },

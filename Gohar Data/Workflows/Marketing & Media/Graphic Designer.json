    {
      "parameters": {
        "jsCode": "// Get the raw output from LLM\nconst rawOutput = $input.all()[0].json.text;\n\n// Remove any markdown code blocks if present\nlet cleanedOutput = rawOutput\n  .replace(/```json\\n?/g, '')\n  .replace(/```\\n?/g, '')\n  .trim();\n\n// Extract JSON from first { to last }\nconst firstBrace = cleanedOutput.indexOf('{');\nconst lastBrace = cleanedOutput.lastIndexOf('}');\n\nif (firstBrace === -1 || lastBrace === -1) {\n  throw new Error('No valid JSON object found in output');\n}\n\ncleanedOutput = cleanedOutput.substring(firstBrace, lastBrace + 1);\n\n// Parse the JSON\nlet parsedData;\ntry {\n  parsedData = JSON.parse(cleanedOutput);\n} catch (error) {\n  throw new Error(`Failed to parse JSON: ${error.message}\\n\\nCleaned output:\\n${cleanedOutput}`);\n}\n\n// Validate required fields\nconst requiredFields = [\n  'enhanced_prompt',\n  'technical_keywords',\n  'aspect_ratio',\n  'resolution',\n  'style_tag',\n  'mood_tag'\n];\n\nconst missingFields = requiredFields.filter(field => !parsedData[field]);\n\nif (missingFields.length > 0) {\n  throw new Error(`Missing required fields: ${missingFields.join(', ')}`);\n}\n\n// Return clean structured data\nreturn {\n  json: {\n    enhanced_prompt: parsedData.enhanced_prompt,\n    technical_keywords: parsedData.technical_keywords,\n    aspect_ratio: parsedData.aspect_ratio,\n    resolution: parsedData.resolution,\n    style_tag: parsedData.style_tag,\n    mood_tag: parsedData.mood_tag,\n    // Optional: keep original for debugging\n  }\n};"
      },

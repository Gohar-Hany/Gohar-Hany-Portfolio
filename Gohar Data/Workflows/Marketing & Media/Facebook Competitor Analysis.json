        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n    \"executive_summary\": {\n      \"type\": \"string\",\n      \"description\": \"3-5 key findings in bullet points\"\n    },\n    \"brand_identity_assessment\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"consistency_score\": {\"type\": \"number\", \"minimum\": 1, \"maximum\": 10},\n        \"personality_traits\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}},\n        \"positioning_statement\": {\"type\": \"string\"}\n      }\n    },\n    \"content_strategy_breakdown\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"whats_working\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}},\n        \"whats_not_working\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}},\n        \"content_pillars\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}}\n      }\n    },\n    \"visual_design_audit\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"quality_rating\": {\"type\": \"string\", \"enum\": [\"excellent\", \"good\", \"average\", \"poor\"]},\n        \"design_trends\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}},\n        \"effectiveness_score\": {\"type\": \"number\", \"minimum\": 1, \"maximum\": 10}\n      }\n    },\n    \"engagement_analysis\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"top_engagement_drivers\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"maxItems\": 5},\n        \"avg_engagement_rate\": {\"type\": \"string\"}\n      }\n    },\n    \"swot_analysis\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"strengths\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"maxItems\": 5},\n        \"weaknesses\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"maxItems\": 5},\n        \"opportunities\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"maxItems\": 5},\n        \"threats\": {\"type\": \"array\", \"items\": {\"type\": \"string\"}, \"maxItems\": 5}\n      }\n    },\n    \"strategic_recommendations\": {\n      \"type\": \"array\",\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"priority\": {\"type\": \"string\", \"enum\": [\"high\", \"medium\", \"low\"]},\n          \"action\": {\"type\": \"string\"},\n          \"expected_impact\": {\"type\": \"string\"}\n        }\n      },\n      \"maxItems\": 10\n    },\n    \"key_metrics\": {\n      \"type\": \"object\",\n      \"properties\": {\n        \"total_posts_analyzed\": {\"type\": \"number\"},\n        \"avg_engagement_rate\": {\"type\": \"number\"},\n        \"brand_consistency_score\": {\"type\": \"number\"},\n        \"visual_quality_score\": {\"type\": \"number\"}\n      }\n    }\n  },\n  \"required\": [\"executive_summary\", \"swot_analysis\", \"strategic_recommendations\"]\n}"

    {
      "parameters": {
        "jsCode": "// كود n8n المعدل - بيحافظ على الـ structure المتوقع من Google Sheets\n\nfor (const item of $input.all()) {\n  try {\n    // استخراج الـ Content من الـ item\n    const contentString = item.json.Content;\n    \n    // تحويل الـ string لـ JSON object\n    const parsedContent = JSON.parse(contentString);\n    \n    // بناء الـ structure المطلوب بالضبط\n    const output = {\n      // معلومات الصورة من Loop Over Images\n      image_metadata: {\n        url: item.json.url,\n        type: item.json.type,\n        context: item.json.context,\n        postId: item.json.postId || null,\n        text: item.json.text || null,\n        engagement: item.json.engagement || null,\n        publishDate: item.json.publishDate || null,\n        carouselIndex: item.json.carouselIndex || null\n      },\n      \n      // التحليل المفصول\n      analysis: parsedContent,\n      \n      // timestamp\n      analyzed_at: new Date().toISOString()\n    };\n    \n    // استبدال الـ item بالـ structure الجديد\n    item.json = output;\n    \n  } catch (error) {\n    // في حالة حصول خطأ - نحتفظ بالـ data الأصلية\n    item.json = {\n      error: true,\n      message: error.message,\n      original_data: item.json,\n      analyzed_at: new Date().toISOString()\n    };\n  }\n}\n\nreturn $input.all();"
      },

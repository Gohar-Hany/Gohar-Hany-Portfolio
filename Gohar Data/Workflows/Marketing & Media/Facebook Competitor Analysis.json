    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_GROQ_API_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  \"model\": \"meta-llama/llama-4-scout-17b-16e-instruct\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert brand strategist and visual analyst specializing in social media marketing. Analyze images with a focus on: branding elements, design patterns, color psychology, messaging strategy, emotional triggers, and competitive positioning. Always respond in valid JSON format.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"Analyze this \" + $json.type + \" image from a Facebook page.\\n\\nContext: \" + $json.context + (($json.text) ? \"\\n\\nPost Text: \" + $json.text : \"\") + \"\\n\\nProvide comprehensive analysis in strict JSON format with these fields:\\n\\n{\\n  \\\"visual_elements\\\": {\\n    \\\"primary_colors\\\": [\\\"list of hex codes or color names\\\"],\\n    \\\"color_psychology\\\": \\\"what emotions/associations these colors evoke\\\",\\n    \\\"typography\\\": {\\n      \\\"fonts_used\\\": [\\\"font names if identifiable\\\"],\\n      \\\"text_hierarchy\\\": \\\"description of text layout\\\",\\n      \\\"readability_score\\\": \\\"1-10 rating\\\"\\n    },\\n    \\\"composition\\\": \\\"layout type (grid/asymmetric/centered etc)\\\",\\n    \\\"design_style\\\": \\\"modern/minimalist/corporate/creative etc\\\"\\n  },\\n  \\\"branding\\\": {\\n    \\\"logo_visible\\\": true/false,\\n    \\\"logo_placement\\\": \\\"position and prominence\\\",\\n    \\\"brand_consistency\\\": \\\"1-10 rating with explanation\\\",\\n    \\\"brand_personality\\\": [\\\"list of traits: professional, playful, innovative, etc\\\"]\\n  },\\n  \\\"content_analysis\\\": {\\n    \\\"main_message\\\": \\\"core message being communicated\\\",\\n    \\\"call_to_action\\\": \\\"explicit or implicit CTA\\\",\\n    \\\"target_audience\\\": \\\"inferred audience demographic\\\",\\n    \\\"emotional_tone\\\": \\\"inspirational/educational/promotional etc\\\",\\n    \\\"content_type\\\": \\\"infographic/quote/product/service/announcement etc\\\"\\n  },\\n  \\\"marketing_strategy\\\": {\\n    \\\"engagement_potential\\\": \\\"1-10 rating\\\",\\n    \\\"engagement_factors\\\": [\\\"what makes this engaging or not\\\"],\\n    \\\"value_proposition\\\": \\\"what value is offered to the audience\\\",\\n    \\\"differentiation\\\": \\\"how this stands out from competitors\\\",\\n    \\\"improvement_suggestions\\\": [\\\"2-3 actionable improvements\\\"]\\n  },\\n  \\\"technical_quality\\\": {\\n    \\\"image_quality\\\": \\\"professional/good/average/poor\\\",\\n    \\\"resolution_estimate\\\": \\\"high/medium/low\\\",\\n    \\\"design_tools_likely_used\\\": [\\\"Canva/Photoshop/Figma etc\\\"]\\n  },\\n  \\\"competitive_insights\\\": {\\n    \\\"industry_alignment\\\": \\\"how well this aligns with industry standards\\\",\\n    \\\"trend_adoption\\\": \\\"current/dated/ahead of trends\\\",\\n    \\\"unique_elements\\\": [\\\"what makes this unique\\\"],\\n    \\\"common_elements\\\": [\\\"what follows common patterns\\\"]\\n  },\\n  \\\"overall_assessment\\\": {\\n    \\\"effectiveness_score\\\": \\\"1-10 rating\\\",\\n    \\\"strengths\\\": [\\\"3-5 key strengths\\\"],\\n    \\\"weaknesses\\\": [\\\"3-5 areas for improvement\\\"],\\n    \\\"strategy_category\\\": \\\"brand awareness/lead gen/engagement/education etc\\\"\\n  }\\n}\\n\\nBe specific, analytical, and actionable in your assessment.\"\n        },\n        {\n          \"type\": \"image_url\",\n          \"image_url\": {\n            \"url\": $json.url\n          }\n        }\n      ]\n    }\n  ],\n  \"response_format\": {\n    \"type\": \"json_object\"\n  },\n  \"temperature\": 0.7,\n  \"max_completion_tokens\": 2048\n} }}",
        "options": {}
      },

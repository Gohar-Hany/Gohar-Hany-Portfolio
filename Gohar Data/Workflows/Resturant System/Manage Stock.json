      "parameters": {
        "jsCode": "const summary = items.map(item => {\n  const data = item.json;\n  const name = data.Item || data.itemName || 'Unknown';\n  const quantity = data.quantity;\n  const unit = data.unit ?? '';\n  \n  return `- ${name}: Current total ${quantity} ${unit}`;\n}).join('\\n');\n\nreturn [\n  {\n    json: {\n      message: `Inventory updated:\\n${summary}`\n    }\n  }\n];"

      "id": "57086c35-0615-439b-bcc9-29e94c3b7a1d",
      "name": "Groq LLM",
      "credentials": {
        "groqApi": {
          "id": "sUaxWBZcp4YFdgw2",
          "name": "Groq account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Combine all transcript items into a single context for the AI Agent\nconst allItems = $input.all();\n\nlet combinedText = \"Project: Kayanova - Voice Transcripts Summary\\n\";\ncombinedText += \"============================================\\n\\n\";\n\nallItems.forEach((item, index) => {\n  if (item.json.text) {\n    combinedText += `[Record ${index + 1}]:\\n${item.json.text}\\n\\n`;\n  }\n});\n\nreturn {\n  combined_context: combinedText,\n  total_records: allItems.length,\n  timestamp: new Date().toISOString()\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [

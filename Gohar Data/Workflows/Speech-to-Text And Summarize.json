        "text": "={{ $json.combined_context }}",
        "options": {
          "systemMessage": "=# Role: Technical Project Manager & Business Analyst\n\n## Context\nYou are an expert Technical Project Manager for Kayanova. Your task is to process audio transcripts of team discussions. Extract tasks, requirements, and deadlines into a structured report.\n\n## Output Structure:\n1. Executive Summary\n2. Action Items (High/Low Priority)\n3. Technical Specs (API, JSON, Logic)\n4. UI/UX Changes\n5. Risks & Timeline",
          "enableStreaming": false
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3,
      "position": [
        1008,
        -432
      ],

    {
      "parameters": {
        "jsCode": "// Mapping binary keys to 'data' for Groq compatibility\nfor (const item of items) {\n  if (item.binary) {\n    const keys = Object.keys(item.binary);\n    if (keys.length > 0) {\n      item.binary.data = item.binary[keys[0]];\n    }\n  }\n}\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
